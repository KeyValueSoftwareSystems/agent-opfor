{
  "name": "@astra/mcp",
  "version": "0.0.1",
  "description": "Astra CLI — security testing for MCP servers and AI agents (astra setup|generate|run)",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "src/agent/core",
    "src/agent/mcp",
    "src/agent/cli"
  ],
  "bin": {
    "astra": "./dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run build:agent && npm run build:mcp",
    "build:agent": "npm run build --workspace=@astra/core && npm run build --workspace=@astra/agent-mcp-server && npm run build --workspace=astra-cli",
    "build:mcp": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "astra-cli": "*",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "dotenv": "^16.4.7",
    "yaml": "^2.8.3",
    "zod": "^4.1.5"
  }
}
