{
  "name": "@opfor/autonomous",
  "version": "0.1.0",
  "description": "Opfor Autonomous — a Claude-Agent-SDK-native adaptive red-team agent that autonomously attacks a target agent and self-judges",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "opfor-auto": "./dist/index.js"
  },
  "files": [
    "dist/",
    "data/"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run build:ui && tsc -p tsconfig.json",
    "build:ui": "cd ui && npm install && npm run build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx/esm --test tests/*.test.ts",
    "ui:demo": "npm run build && node dist/index.js ui-demo",
    "ui": "npm run build && node dist/index.js ui"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.165",
    "@anthropic-ai/sdk": "^0.100.1",
    "@opfor/core": "*",
    "commander": "^14.0.1",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "yaml": "^2.8.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
